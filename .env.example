# Proxmox
PROXMOX_HOST=192.168.x.x
PROXMOX_USER=root@pam
PROXMOX_TOKEN_NAME=mcp-token
PROXMOX_TOKEN_VALUE=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
PROXMOX_VERIFY_SSL=false

# Paths (on Raspberry Pi)
TERRAFORM_DIR=/root/proxpox-lab/terraform
ANSIBLE_DIR=/root/proxpox-lab/ansible
KUBECONFIG=/root/.kube/config

# SSH (for lab_exec)
SSH_USER=ubuntu
SSH_KEY=/root/.ssh/id_rsa

# Server
MCP_HOST=0.0.0.0
MCP_PORT=8000
