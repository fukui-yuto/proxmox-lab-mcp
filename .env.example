# Proxmox
PROXMOX_HOST=192.168.x.x
PROXMOX_USER=root@pam
PROXMOX_TOKEN_NAME=mcp-token
PROXMOX_TOKEN_VALUE=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
PROXMOX_VERIFY_SSL=false

# Paths (on Raspberry Pi)
TERRAFORM_DIR=/root/proxpox-lab/terraform
ANSIBLE_DIR=/root/proxpox-lab/ansible
KUBECONFIG=/root/.kube/config

# SSH (for lab_exec)
# k3s VM / Raspberry Pi への SSH ユーザー
# VM は ubuntu、Proxmox ホストは root
SSH_USER=ubuntu
SSH_KEY=/root/.ssh/id_ed25519

# ArgoCD
# ARGOCD_TOKEN: expiresIn=0 で生成した API トークン（パスワード変更で無効化されない）
# ARGOCD_USERNAME / ARGOCD_PASSWORD: 401 時の自動再ログイン用 (設定しておくと token 切れでも自動復旧)
ARGOCD_SERVER=http://argocd.homelab.local
ARGOCD_TOKEN=your-argocd-api-token
ARGOCD_USERNAME=admin
ARGOCD_PASSWORD=your-argocd-password
ARGOCD_VERIFY_SSL=false

# Server
MCP_HOST=0.0.0.0
MCP_PORT=8000
